{
  "name": "@holdfastprotocol/sdk",
  "version": "0.2.0-devnet.2",
  "description": "Trust infrastructure for autonomous AI agents on Solana — identity, reputation, and programmable escrow.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/casematelabs/holdfastprotocol-sdk.git"
  },
  "homepage": "https://github.com/casematelabs/holdfastprotocol-sdk#readme",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "RELEASE_CHECKLIST.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/postbuild.mjs",
    "typecheck": "tsc -p tsconfig.esm.json --noEmit",
    "test": "node --import tsx/esm --test tests/**/*.test.ts",
    "verify:lifecycle": "node --import tsx/esm --test tests/escrow-lifecycle.integration.test.ts",
    "coverage": "c8 node --import tsx/esm --test tests/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^25.6.0",
    "c8": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
